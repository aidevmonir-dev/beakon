# Frontend local config — copy to .env.local and edit.
#
# When running everything locally, leave this file alone (or copy to .env.local
# without changes). The frontend defaults to http://localhost:8000/api/v1.
#
# When tunnelling through Cloudflare for a remote demo (e.g. Thomas review):
# 1. In a terminal:  cloudflared tunnel --url http://localhost:8000
# 2. Copy the printed https://*.trycloudflare.com URL
# 3. Paste it below as NEXT_PUBLIC_API_BASE (with /api/v1 suffix)
# 4. Restart Next:  npm run dev
# 5. In another terminal:  cloudflared tunnel --url http://localhost:3000
# 6. Send the second URL to Thomas

# Full URL including /api/v1 — overrides everything else
# NEXT_PUBLIC_API_BASE=https://random-words-here.trycloudflare.com/api/v1

# Or just the host (we append /api/v1 automatically)
# NEXT_PUBLIC_API_HOST=https://random-words-here.trycloudflare.com
